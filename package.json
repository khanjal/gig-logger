{
  "name": "raptor-gig",
  "version": "0.0.0",
  "browser": {
    "child_process": false,
    "fs": false,
    "process": false,
    "net": false,
    "tls": false
  },
  "files": [
    "./src",
    "./dist"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "serve:ssl": "ng serve --host gig-local.raptorsheets.com --ssl",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "build:stage": "ng build --configuration staging",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "check:zoneless-runtime": "node scripts/check-zoneless-runtime.js",
    "update-lambda": "node scripts/update-lambda.js",
    "setup-metrics": "node scripts/setup-metrics.js"
  },
  "private": true,
  "overrides": {
    "karma": {
      "minimatch": "^3.1.5"
    },
    "minimatch": "^10"
  },
  "dependencies": {
    "@angular/animations": "^22.0.4",
    "@angular/cdk": "~22.0.2",
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/forms": "^22.0.4",
    "@angular/material": "~22.0.2",
    "@angular/platform-browser": "^22.0.4",
    "@angular/platform-browser-dynamic": "^22.0.4",
    "@angular/router": "^22.0.4",
    "@angular/service-worker": "^22.0.4",
    "@auth0/angular-jwt": "^5.2.0",
    "angular-oauth2-oidc": "^22.0.2",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "dexie": "^4.4.4",
    "ng2-charts": "^10.0.0",
    "ngx-mat-timepicker": "^21.0.1",
    "rxjs": "^7.8.2",
    "uuid": "^14.0.1",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.4",
    "@types/jasmine": "^6.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "autoprefixer": "^10.4.22",
    "buffer": "^6.0.3",
    "jasmine-core": "^6.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "postcss": "^8.5.6",
    "process": "^0.11.10",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  }
}
